# Database - Neon PostgreSQL
DATABASE_URL="postgresql://username:password@host.neon.tech/database?sslmode=require"

# Email Domain - domain yang digunakan untuk menerima email
# Contoh: tempmail.example.com
NEXT_PUBLIC_EMAIL_DOMAIN="your-email-domain.com"

# Webhook Secret - token rahasia untuk autentikasi webhook dari Cloudflare Worker
# Buat random string, contoh: openssl rand -hex 32
WEBHOOK_SECRET="your-webhook-secret-here"

# Admin Password - password untuk login ke admin dashboard (/admin)
ADMIN_PASSWORD="your-admin-password-here"
